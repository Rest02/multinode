// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación 1:N (Un usuario crea muchas notas)
  notes Note[] @relation("NoteAuthor")

  // Relación 1:N (Un usuario crea muchas libretas)
  notebooks Notebook[] @relation("NotebookAuthor")

  // Relación N:M (Un usuario tiene muchas notas favoritas)
  favoriteNotes Note[] @relation("FavoriteNotes")
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String // En PostgreSQL, String por defecto mapea al tipo de datos 'text'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con el autor
  authorId String
  author   User   @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Relación opcional con una libreta
  notebookId String?
  notebook   Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)

  // Relación N:M (Una nota tiene muchas etiquetas, una etiqueta pertenece a muchas notas)
  tags Tag[] @relation("NoteTags")

  // Relación N:M inversa de notas favoritas
  favoritedBy User[] @relation("FavoriteNotes")
}

model Notebook {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con el autor
  authorId String
  author   User   @relation("NotebookAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Notas que pertenecen a esta libreta
  notes Note[]
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // Relación N:M inversa
  notes Note[] @relation("NoteTags")
}
